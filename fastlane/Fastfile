# frozen_string_literal: true

default_platform(:ios)

XCODEPROJ = "MusicWall.xcodeproj"
SCHEME = "MusicWall"

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_KEY_ID"),
    issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
    key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT"),
    is_key_content_base64: true
  )
end

platform :ios do
  desc "Simulator build only (no signing upload)"
  lane :ci_build do
    build_app(
      scheme: SCHEME,
      project: XCODEPROJ,
      skip_archive: true,
      skip_package_ipa: true,
      destination: "generic/platform=iOS Simulator",
      sdk: "iphonesimulator"
    )
  end

  desc "PR preview: TestFlight internal"
  lane :preview do
    setup_ci if ENV["CI"]
    match(type: "appstore", readonly: true, app_identifier: "chris.MusicWall")

    increment_build_number(
      build_number: ENV.fetch("BUILD_NUMBER"),
      xcodeproj: XCODEPROJ
    )

    build_app(
      scheme: SCHEME,
      project: XCODEPROJ,
      export_method: "app-store",
      output_directory: "./build",
      clean: true
    )

    upload_to_testflight(
      api_key: asc_api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end

  desc "Tagged release: App Store upload and submit for review"
  lane :release do
    setup_ci if ENV["CI"]
    match(type: "appstore", readonly: true, app_identifier: "chris.MusicWall")

    increment_version_number(
      version_number: ENV.fetch("RELEASE_VERSION"),
      xcodeproj: XCODEPROJ
    )
    increment_build_number(
      build_number: ENV.fetch("BUILD_NUMBER"),
      xcodeproj: XCODEPROJ
    )

    build_app(
      scheme: SCHEME,
      project: XCODEPROJ,
      export_method: "app-store",
      output_directory: "./build",
      clean: true
    )

    upload_to_app_store(
      api_key: asc_api_key,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      skip_metadata: true,
      skip_screenshots: true
    )
  end
end
