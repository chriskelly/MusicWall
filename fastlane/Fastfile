# frozen_string_literal: true

default_platform(:ios)

XCODEPROJ = "MusicWall.xcodeproj"
SCHEME = "MusicWall"
TARGET = "MusicWall"
BUNDLE_ID = ENV["APP_IDENTIFIER"] || "chris.MusicWall"
TEAM_ID = ENV["DEVELOPMENT_TEAM"] || "CD8XP2U645"

def asc_key_params
  {
    key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_KEY_ID"),
    issuer_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ISSUER_ID"),
    key_content: ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT"),
    is_key_content_base64: true
  }
end

def asc_api_key
  app_store_connect_api_key(**asc_key_params)
end

def connect_api_token
  params = asc_key_params
  Spaceship::ConnectAPI::Token.create(
    key_id: params[:key_id],
    issuer_id: params[:issuer_id],
    key: params[:key_content],
    is_key_content_base64: params[:is_key_content_base64]
  )
end

def appstore_profile_name
  mapping = lane_context[SharedValues::MATCH_PROVISIONING_PROFILE_MAPPING] || {}
  mapping[BUNDLE_ID] || "match AppStore #{BUNDLE_ID}"
end

def configure_appstore_signing
  profile = appstore_profile_name

  update_code_signing_settings(
    use_automatic_signing: false,
    path: XCODEPROJ,
    team_id: TEAM_ID,
    targets: [TARGET],
    bundle_identifier: BUNDLE_ID,
    profile_name: profile,
    code_sign_identity: "Apple Distribution"
  )
end

def prepare_appstore_signing
  setup_ci if ENV["CI"]
  match(type: "appstore", readonly: true, app_identifier: BUNDLE_ID)
  configure_appstore_signing
end

def xcodeproj_file_path(xcodeproj = XCODEPROJ)
  File.expand_path("../#{xcodeproj}", __dir__)
end

def set_target_version_in_project(marketing_version: nil, build_number: nil, xcodeproj: XCODEPROJ, target_name:)
  require "xcodeproj"

  project_path = xcodeproj_file_path(xcodeproj)
  project = Xcodeproj::Project.open(project_path)
  native_target = project.targets.find { |t| t.name == target_name }
  UI.user_error!("Xcode target #{target_name} not found in #{project_path}") unless native_target

  native_target.build_configurations.each do |config|
    config.build_settings["MARKETING_VERSION"] = marketing_version.to_s if marketing_version
    config.build_settings["CURRENT_PROJECT_VERSION"] = build_number.to_s if build_number
  end

  project.save
end

def build_appstore_ipa(marketing_version: nil, build_number: nil)
  profile = appstore_profile_name
  xcargs = {
    CODE_SIGN_STYLE: "Manual",
    PROVISIONING_PROFILE_SPECIFIER: profile,
    DEVELOPMENT_TEAM: TEAM_ID
  }
  xcargs[:MARKETING_VERSION] = marketing_version if marketing_version
  xcargs[:CURRENT_PROJECT_VERSION] = build_number.to_s if build_number

  build_app(
    scheme: SCHEME,
    project: XCODEPROJ,
    export_method: "app-store",
    output_directory: "./build",
    clean: true,
    codesigning_identity: "Apple Distribution",
    xcargs: xcargs,
    export_options: {
      provisioningProfiles: {
        BUNDLE_ID => profile
      }
    }
  )
end

def latest_app_store_version_string
  Spaceship::ConnectAPI.token = connect_api_token
  app = Spaceship::ConnectAPI::App.find(BUNDLE_ID)
  return nil unless app

  versions = app.get_app_store_versions(limit: 100)
  strings = versions.map(&:version_string).compact
  strings.max_by { |s| Gem::Version.new(s) }
rescue StandardError => e
  UI.important("Could not read App Store Connect versions (#{e.message}); using project marketing version only.")
  nil
end

def bump_patch_version(version_string)
  segments = version_string.split(".")
  segments << "0" if segments.length < 2
  segments[-1] = (segments[-1].to_i + 1).to_s
  segments.join(".")
end

def resolve_marketing_version_for_preview
  project_version = get_version_number(xcodeproj: XCODEPROJ, target: TARGET)
  connect_latest = latest_app_store_version_string

  target = project_version
  if connect_latest && Gem::Version.new(project_version) <= Gem::Version.new(connect_latest)
    target = bump_patch_version(connect_latest)
    UI.message(
      "Marketing version #{project_version} is not above App Store Connect (#{connect_latest}); " \
      "using #{target} for this TestFlight upload."
    )
  end

  # agvtool does not update explicit MARKETING_VERSION build settings in modern Xcode projects.
  set_target_version_in_project(
    marketing_version: target,
    xcodeproj: XCODEPROJ,
    target_name: TARGET
  )
  target
end

def resolve_build_number_for_upload(version: nil)
  # App-wide monotonic CFBundleVersion (Apple rejects reuse across any version train).
  returned = latest_testflight_build_number(
    api_key: asc_api_key,
    initial_build_number: 1
  ).to_i

  latest = lane_context[SharedValues::LATEST_TESTFLIGHT_BUILD_NUMBER].to_i
  # Action can return the current latest; always bump above ASC's highest uploaded build.
  next_build = [returned, latest + 1].max

  floor = ENV.fetch("BUILD_NUMBER", "1").to_i
  next_build = [next_build, floor].max if floor.positive? && floor < 10_000_000

  UI.message(
    "Build number #{next_build} (App Store Connect latest: #{latest}" \
    "#{version ? ", marketing version #{version}" : ''})."
  )
  next_build
rescue StandardError => e
  UI.important("Could not read latest build from App Store Connect (#{e.message}); using BUILD_NUMBER.")
  ENV.fetch("BUILD_NUMBER", "1")
end

def run_app_store_metadata_precheck
  precheck(
    api_key: asc_api_key,
    app_identifier: BUNDLE_ID,
    include_in_app_purchases: false,
    default_rule_level: :error
  )
end

platform :ios do
  desc "Simulator build only (no signing upload; local / no-deploy)"
  lane :ci_build do
    build_app(
      scheme: SCHEME,
      project: XCODEPROJ,
      skip_archive: true,
      skip_package_ipa: true,
      destination: "generic/platform=iOS Simulator",
      sdk: "iphonesimulator"
    )
  end

  desc "CI Tests workflow: unit tests on iOS Simulator"
  lane :ci_tests do
    sh("../Scripts/check_core_imports.sh")
    result_bundle = "../build/MusicWallTestResults.xcresult"
    sh("rm -rf #{result_bundle}")
    sh("mkdir -p ../build")
    sh(
      "xcodebuild test -project ../#{XCODEPROJ} -scheme #{SCHEME} " \
      "-destination 'platform=iOS Simulator,name=iPhone 17' " \
      "-enableCodeCoverage YES " \
      "-resultBundlePath #{result_bundle}"
    )
    sh("../Scripts/check_coverage.sh #{result_bundle}")
  end

  desc "TestFlight Release workflow: internal TestFlight upload"
  lane :testflight_release do
    run_app_store_metadata_precheck
    prepare_appstore_signing
    marketing_version = resolve_marketing_version_for_preview
    build_number = resolve_build_number_for_upload(version: marketing_version)

    set_target_version_in_project(
      build_number: build_number,
      xcodeproj: XCODEPROJ,
      target_name: TARGET
    )

    build_appstore_ipa(
      marketing_version: marketing_version,
      build_number: build_number
    )

    upload_to_testflight(
      api_key: asc_api_key,
      uses_non_exempt_encryption: false,
      skip_waiting_for_build_processing: true,
      distribute_external: false
    )
  end

  desc "App Store precheck only (run locally before release; needs ASC API key env)"
  lane :precheck_release do
    run_app_store_metadata_precheck
  end

  desc "App Store Release workflow: upload and submit for review"
  lane :app_store_release do
    prepare_appstore_signing

    release_version = ENV.fetch("RELEASE_VERSION")
    build_number = resolve_build_number_for_upload(version: release_version)

    set_target_version_in_project(
      marketing_version: release_version,
      build_number: build_number,
      xcodeproj: XCODEPROJ,
      target_name: TARGET
    )

    build_appstore_ipa(
      marketing_version: release_version,
      build_number: build_number
    )

    upload_to_app_store(
      api_key: asc_api_key,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      skip_metadata: false,
      skip_screenshots: true,
      precheck_include_in_app_purchases: false,
      precheck_default_rule_level: :error,
      run_precheck_before_submit: true
    )
  end
end
